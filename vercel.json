{
  "version": 2,
  "builds": [
    {
      "src": "payment_gateway/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "success.html",
      "use": "@vercel/static"
    },
    {
      "src": "aventura.html",
      "use": "@vercel/static"
    },
    {
      "src": "el_espacio_entre_nosotros.pdf",
      "use": "@vercel/static"
    },
    {
      "src": "el_espacio_entre_nosotros.epub",
      "use": "@vercel/static"
    },
    {
      "src": "cover_bilbao_noir_1781746242043.png",
      "use": "@vercel/static"
    },
    {
      "src": "stereorock_real_1781746258607.png",
      "use": "@vercel/static"
    },
    {
      "src": "uribarri_coder_1781746280902.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/submit-lead",
      "dest": "payment_gateway/server.js"
    },
    {
      "src": "/create-checkout-session",
      "dest": "payment_gateway/server.js"
    },
    {
      "src": "/config",
      "dest": "payment_gateway/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(submit-lead|create-checkout-session|config)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
