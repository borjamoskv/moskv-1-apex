    against=HEAD
else
    against=4b825dc642cb6eb9a060e54bf8d69288fbee4904
fi

# Check for Anergy in staged files (excluding this hook script itself)
if git diff --cached --name-only | grep -v "pre-commit" | xargs grep -i -e "apologize" -e "as an AI" >/dev/null 2>&1; then
    echo -e "\033[0;31m[CRITICAL] ANERGY DETECTED IN STAGED FILES.\033[0m"
    echo "MOSKV-1 APEX does not tolerate LLM Slop. Purge the noise and commit again."
    exit 1
fi

# Check for R5 Critical Path Violations in staged files (excluding this hook script itself)
if git diff --cached --name-only | grep -v "pre-commit" | xargs grep -i -E "/private/var/db/|/System/Volumes/Data/System/Library/AssetsV2|~/Library/Mobile\ Documents|colima" >/dev/null 2>&1; then
    echo -e "\033[0;31m[CRITICAL] R5 CRITICAL PATH VIOLATION DETECTED.\033[0m"
    echo "Attempts to mutate system critical paths (/private/var/db, System, Mobile Documents, Colima) are blocked by Git Sentinel."
    exit 1
fi

echo -e "\033[0;34m[MOSKV-1] Exergy Validated. Committing to C5-REAL Ledger.\033[0m"
exit 0
