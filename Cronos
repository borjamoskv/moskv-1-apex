def mutate_text(text, entropy):
    if entropy < 0.05:
        return text
    chars = list(text)
    num_mutations = int(len(chars) * entropy * 0.15)
    for _ in range(num_mutations):
        idx = random.randint(0, len(chars) - 1)
        if chars[idx].isalnum() and chars[idx] != ' ' and chars[idx] != '\n':
            chars[idx] = random.choice(["ø", "æ", "1", "0", "¶", "§", "Ø", "α", "β", "λ"])
    return "".join(chars)

